<?xml version="1.0"?>
<Booklet xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="https://w3id.org/iqb/spec/testcenter-booklet-xml/18.0">
  <Metadata>
    <Id>booklet1</Id>
    <Label>Beispieltestheft 1</Label>
  </Metadata>
  <BookletConfig>
    <Config key="pagingMode">separate</Config>
    <Config key="page_navibuttons">SEPARATE_BOTTOM</Config>
    <Config key="unit_navibuttons">FULL</Config>
    <Config key="controller_design">2018</Config>
    <Config key="unit_screenheader">WITH_UNIT_TITLE</Config>
    <Config key="unit_title">ON</Config>
  </BookletConfig>
  <Units>
    <Unit id="testcenter-sample1" label="Beispiel-Unit 1" labelshort="1"/>
    <Testlet id="a_testlet_with_restrictions" label="First Block">
      <Restrictions>
        <CodeToEnter code="sample">Please insert the word `sample`.</CodeToEnter>
        <TimeMax minutes="1" />
      </Restrictions>
      <Unit id="testcenter-sample2" label="Beispiel-Unit 2" labelshort="2"/>
    </Testlet>
    <Unit id="testcenter-sample3" label="Beispiel-Unit 3" labelshort="3"/>
  </Units>
</Booklet>

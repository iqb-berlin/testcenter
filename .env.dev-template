# Ingress
HOSTNAME=localhost
HTTP_PORT=80

# Images
## Dockerhub Proxy
DOCKERHUB_PROXY=
## Container Restart Policy. Allowed values are: no, always (default), on-failure, unless-stopped
RESTART_POLICY=no

# Services
## Backend
BROADCASTER_ENABLED=true
FILE_SERVER_ENABLED=true

### Security
PASSWORD_SALT=t

### Init Parameters
#### These parameters may be used for additional init options of the backend.
#### Setting OVERWRITE_INSTALLATION to "yes" overwrites the existing installation.
#### Default value is "no", which means that existing installation will not be overwritten
OVERWRITE_INSTALLATION="no"
#### Setting SKIP_READ_FILES to "yes" skips the reading of file during start-up.
#### Default value is "no"", which means that all files will be read and checked on start-up.
SKIP_READ_FILES="no"
#### Setting SKIP_DB_INTEGRITY to "yes" skips the database integrity check during start-up.
#### Default value is "no", which means that the database integrity will be checked on start-up.
SKIP_DB_INTEGRITY="no"
#### Setting NO_SAMPLE_DATA to "yes" will not create a sample workspace.
#### Default value is "no", which means that a sample workspace with sample data will be created.
NO_SAMPLE_DATA="no"

### Object Storage (S3-compatible: MinIO / AWS S3 / STACKIT)
#### By default the backend stores workspace files on the local filesystem
#### (STORAGE_DRIVER=filesystem). Set STORAGE_DRIVER=s3 to store them in an
#### S3-compatible bucket instead and serve them via presigned-URL redirects.
####
#### The stack is endpoint-agnostic and no S3 is bundled: point the S3_* vars
#### below at any S3 you provide — a MinIO instance you run yourself, AWS S3, or
#### STACKIT. Just set STORAGE_DRIVER=s3 + OBJECT_STORE_ENABLED=true and fill in
#### the endpoints/credentials.
####
#### Optional: run a local MinIO on the compose network (so the "minio" hostname
#### resolves for the backend/file-server) — then the defaults below work as-is:
####   docker run -d --name minio --network testcenter -p 9000:9000 -p 9001:9001 \
####     -e MINIO_ROOT_USER=minioadmin -e MINIO_ROOT_PASSWORD=minioadmin \
####     minio/minio server /data --console-address ":9001"
####   docker run --rm --network testcenter --entrypoint sh minio/mc -c \
####     "mc alias set l http://minio:9000 minioadmin minioadmin && mc mb -p l/tc-files"
#### MinIO ships permissive CORS by default, so no bucket CORS config is needed
#### locally; STACKIT/AWS need a CORS rule allowing http://localhost.
STORAGE_DRIVER=filesystem
#### --- the following apply only when STORAGE_DRIVER=s3 ---
#### Internal endpoint the backend/file-server use to reach the S3 service
#### (the local-MinIO hostname above, or your external S3 URL).
S3_ENDPOINT=http://minio:9000
#### Browser-facing endpoint the presigned URL is SIGNED against. Must be
#### reachable from your browser; with MinIO published on :9000 use localhost.
S3_PUBLIC_ENDPOINT=http://localhost:9000
#### S3 region. Any value for MinIO; the real region for AWS/STACKIT.
S3_REGION=us-east-1
#### Bucket that holds the workspace files (create it in MinIO first).
S3_BUCKET=tc-files
#### Path-style addressing. true for MinIO/STACKIT, false for AWS.
S3_USE_PATH_STYLE=true
#### Use TLS for the internal endpoint. false for local http MinIO.
S3_USE_SSL=false
#### Lifetime of presigned download URLs, in seconds.
S3_PRESIGN_TTL=3600
#### Credentials. For local MinIO these are the MinIO root user/password.
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
#### File-server toggle: serve via presigned-URL redirect instead of the local
#### data volume. Set to "true" together with STORAGE_DRIVER=s3.
OBJECT_STORE_ENABLED=false
#### FQDN the file-server uses to reach the backend for presign subrequests.
BACKEND_URL=http://backend:8080

## Cache Service
REDIS_PASSWORD=change_me
### Allowed memory usage for cache in byte. 2147483648 = 2GB. Default is 1GB.
REDIS_MEMORY_MAX=1gb
### Should whole files be cached or only authentication tokens
REDIS_CACHE_FILES=false

## Database
MYSQL_ROOT_PASSWORD=secret_root_pw
MYSQL_DATABASE=iqb_tba_testcenter
MYSQL_USER=iqb_tba_db_user
MYSQL_PASSWORD=iqb_tba_db_password
MYSQL_BINLOG_EXPIRE_LOGS_SECONDS=691200

# Network
## MTU Setting. Default is 1500, but Openstack actually uses 1442
DOCKER_DAEMON_MTU=1500
